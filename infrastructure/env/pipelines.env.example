PIPELINES_URLS=https://github.com/open-webui/pipelines/blob/main/examples/filters/libretranslate_filter_pipeline.py
PG_CONN_STR=postgresql://${PGVECTOR_USR}:${PGVECTOR_PASS}@vdb/pgvdb
OLLAMA_BASE_URL=http://ollama:11434
# VDB_PORT must be the internal network port (usually 5432), not the host-exposed port (5433).
VDB_HOST=vdb
VDB_PORT=5432
VDB_USER=${PGVECTOR_USR}
VDB_PASSWORD=${PGVECTOR_PASS}
VDB_DBNAME=pgvdb
CHAT_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text
